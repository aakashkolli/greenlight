{
  "name": "greenlight",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "contracts"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:prewarm\"",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "dev:prewarm": "node scripts/prewarm-dev.mjs",
    "dev:chain": "npm --workspace contracts run node",
    "deploy": "npm --workspace contracts run deploy",
    "db:push": "npm --workspace backend run db:push",
    "db:reset": "npm --workspace backend run db:reset",
    "db:setup": "npm run db:push && npm run seed",
    "seed": "npm --workspace backend run seed",
    "test:contracts": "npm --workspace contracts run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^8.2.2",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
